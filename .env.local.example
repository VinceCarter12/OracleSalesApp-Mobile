# Supabase — ask the project lead for values. NEVER commit the real .env.local
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Postgres session pooler (IPv4) — direct DB access for psql/scripts, NOT used by the app
DATABASE_URL=postgresql://postgres.your-project:your-db-password@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres
